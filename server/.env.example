# Server Configuration
PORT=5000
NODE_ENV=development

# Database (use individual PG vars — avoids URL-encoding issues with special chars in passwords)
PGHOST=aws-1-ap-southeast-2.pooler.supabase.com
PGPORT=6543
PGDATABASE=postgres
PGUSER=postgres.your_project_ref
PGPASSWORD=your_database_password
# Or use a single URL (individual vars take priority if both are set):
# DATABASE_URL=postgresql://user:password@host:port/database

# AI API Keys
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs (Phase 3 — voice synthesis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # default: Rachel

# Authentication — must be a unique secret, min 32 chars, never the example value
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173
# Production example:
# ALLOWED_ORIGINS=https://preplitai.com,https://www.preplitai.com

# Rate limiting (per user, per hour for paid API routes)
RATE_LIMIT_PER_USER_PER_HOUR=20
RATE_LIMIT_GLOBAL_PER_MINUTE=60

# Frontend URL (for email links, redirects)
FRONTEND_URL=http://localhost:8080
